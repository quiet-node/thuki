{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboard": true,
  "enabledManagers": ["custom.regex"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^scripts/ensure-llama-server\\.ts$/"],
      "matchStrings": [
        "const LLAMA_CPP_TAG = '(?<currentValue>b\\d+)';\\nconst LLAMA_CPP_COMMIT = '(?<currentDigest>[0-9a-f]{40})';"
      ],
      "depNameTemplate": "ggml-org/llama.cpp",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "regex:^b(?<major>\\d+)$"
    }
  ],
  "packageRules": [
    {
      "matchDepNames": ["ggml-org/llama.cpp"],
      "schedule": ["before 9am on monday"],
      "minimumReleaseAge": "3 days",
      "commitMessageTopic": "bundled llama.cpp engine",
      "prBodyNotes": [
        "Automated engine bump. The **Engine Regression Gate** is the hard check on this PR. If it reports a dylib closure change, check out this branch, run `bun run engine:ensure` (it prints the exact frameworks diff), update `src-tauri/tauri.conf.json` to match, and push."
      ]
    }
  ]
}
