{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Thuki",
  "version": "0.1.0",
  "identifier": "com.quietnode.thuki",
  "build": {
    "beforeDevCommand": "bun run frontend:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Thuki",
        "width": 600,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": false,
        "visible": false,
        "dragDropEnabled": false
      },
      {
        "label": "settings",
        "title": "Thuki Settings",
        "url": "index.html#/settings",
        "width": 720,
        "height": 560,
        "minWidth": 720,
        "minHeight": 560,
        "maxWidth": 720,
        "maxHeight": 560,
        "resizable": false,
        "fullscreen": false,
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": false,
        "visible": false,
        "skipTaskbar": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: asset: https://asset.localhost;",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/images/**"]
      },
      "capabilities": ["default"]
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
